{
  "name": "coderoad-web-performance",
  "version": "1.0.0",
  "description": "Example website for the \"CodeRoad Web Performance\" workshop.",
  "main": "index.js",
  "scripts": {
    "start": "nodemon ./index.js",
    "bundle": "lightningcss --bundle ./public/assets/css/styles.css -o ./public/assets/css/styles.bundle.css --sourcemap",
    "imagePngResizer": "node ./tools/imagePngResizer.mjs",
    "imagePngOptimize": "node ./tools/imagePngOptimize.mjs",
    "imagePngToWebP": "node ./tools/imagePngToWebP.mjs",
    "deploy": "./tools/deploy.sh"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "web-performance",
    "core-web-vitals",
    "workshop",
    "frontend-masters"
  ],
  "license": "",
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "body-parser": "^2.0.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "express": "^5.0.0",
    "http-compression": "^1.0.20",
    "nodemon": "^3.1.6"
  },
  "nodemonConfig": {
    "ignore": [
      "**/public/**"
    ]
  },
  "devDependencies": {
    "glob": "^11.0.0",
    "lightningcss-cli": "^1.27.0",
    "sharp": "^0.35.1"
  }
}
